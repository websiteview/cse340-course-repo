<%- include('partials/header') %>

<main>

    <h1><%= title %></h1>

    <div class="categories-container">

        <% categories.forEach(category => { %>

            <div class="category-card">

                <h2>
    <a href="/category/<%= category.category_id %>">
        <%= category.name %>
    </a>
</h2>

            </div>

        <% }) %>

    </div>

</main>

<%- include('partials/footer') %>