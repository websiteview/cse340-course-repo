<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <!-- FLASH MESSAGES (si tu header no los muestra aún, esto ayuda) -->
    <% const messages = flash(); %>
    <% Object.keys(messages).forEach(type => { %>
        <% messages[type].forEach(msg => { %>
            <div class="alert <%= type %>">
                <%= msg %>
            </div>
        <% }) %>
    <% }) %>

    <form action="/new-organization" method="POST">

        <div>
            <label for="name">Organization Name</label>
            <input 
                type="text" 
                id="name"
                name="name"
                required
                maxlength="150"
            >
        </div>

        <div>
            <label for="description">Description</label>
            <textarea 
                id="description"
                name="description"
                required
                maxlength="500"
            ></textarea>
        </div>

        <div>
            <label for="contactEmail">Contact Email</label>
            <input 
                type="email" 
                id="contactEmail"
                name="contactEmail"
                required
            >
        </div>

        <button type="submit">Create Organization</button>
    </form>

</main>

<%- include('partials/footer') %>