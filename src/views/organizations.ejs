<%- include('partials/header') %>

<main>

    <h1><%= title %></h1>

    <% if (user && user.role_name === 'admin') { %>

        <p>
            <a href="/new-organization" class="btn">
                ➕ Add New Organization
            </a>
        </p>

    <% } %>

    <div class="organizations-container">

        <% organizations.forEach(org => { %>

            <div class="organization-card">

                <img
                    src="/images/<%= org.logo_filename || 'default.png' %>"
                    alt="<%= org.name %> logo"
                    width="200"
                >

                <h2>
                    <a href="/organization/<%= org.organization_id %>">
                        <%= org.name %>
                    </a>
                </h2>

                <p><%= org.description %></p>

                <p>
                    <strong>Email:</strong>
                    <%= org.contact_email %>
                </p>

            </div>

        <% }) %>

    </div>

</main>

<%- include('partials/footer') %>