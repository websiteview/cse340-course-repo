<%- include('partials/header') %>

<main>

    <div class="project-card">

        <h1><%= project.title %></h1>

        <p>
            <strong>Organization:</strong>

            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <p>
            <strong>Description:</strong>
            <%= project.description %>
        </p>

        <p>
            <strong>Location:</strong>
            <%= project.location %>
        </p>

        <p>
            <strong>Date:</strong>

            <%= new Date(project.project_date).toLocaleDateString(
                'en-US',
                {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                }
            ) %>

        </p>

        <!-- =========================
             VOLUNTEER SECTION
        ========================== -->

        <% if (isLoggedIn) { %>

            <% if (isVolunteer) { %>

                <p>
                    You are volunteering for this project.
                </p>

                <form
                    action="/project/<%= project.project_id %>/unvolunteer"
                    method="POST"
                >
                    <button type="submit">
                        Remove Me as Volunteer
                    </button>
                </form>

            <% } else { %>

                <form
                    action="/project/<%= project.project_id %>/volunteer"
                    method="POST"
                >
                    <button type="submit">
                        Volunteer for this Project
                    </button>
                </form>

            <% } %>

        <% } %>

        <!-- =========================
             ADMIN LINKS
        ========================== -->

        <% if (user && user.role_name === 'admin') { %>

            <p>
                <a href="/edit-project/<%= project.project_id %>">
                    Edit Project
                </a>
            </p>

            <p>
                <a href="/project/<%= project.project_id %>/assign-categories">
                    Edit Categories
                </a>
            </p>

        <% } %>

        <!-- =========================
             CATEGORIES
        ========================== -->

        <div class="categories-container">

            <h3>Categories</h3>

            <% if (categories.length > 0) { %>

                <% categories.forEach(category => { %>

                    <p>

                        <a
                            class="category-tag"
                            href="/category/<%= category.category_id %>"
                        >
                            <%= category.name %>
                        </a>

                    </p>

                <% }) %>

            <% } else { %>

                <p>No categories assigned.</p>

            <% } %>

        </div>

    </div>

</main>

<%- include('partials/footer') %>