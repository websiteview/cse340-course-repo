<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <!-- EDIT ORGANIZATION FORM -->
    <form action="/edit-organization/<%= organization.organization_id %>" method="POST">

        <!-- NAME -->
        <div>
            <label>Organization Name</label>
            <input 
                type="text" 
                name="name" 
                value="<%= organization.name %>" 
                required
                maxlength="150"
            >
        </div>

        <!-- DESCRIPTION -->
        <div>
            <label>Description</label>
            <textarea 
                name="description" 
                required
                maxlength="500"
            ><%= organization.description %></textarea>
        </div>

        <!-- EMAIL -->
        <div>
            <label>Contact Email</label>
            <input 
                type="email" 
                name="contactEmail" 
                value="<%= organization.contact_email %>" 
                required
            >
        </div>

        <!-- LOGO (optional field required by assignment sometimes) -->
        <div>
            <label>Logo Filename</label>
            <input 
                type="text" 
                name="logoFilename" 
                value="<%= organization.logo_filename %>"
            >
        </div>

        <!-- SUBMIT -->
        <button type="submit">Update Organization</button>

    </form>

</main>

<%- include('partials/footer') %>